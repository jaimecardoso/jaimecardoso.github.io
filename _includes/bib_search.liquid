{% comment %}_includes/bib_search.liquid{% endcomment %}

<style>
#pub-filter-bar {
  margin-bottom: 1.6rem;
  font-size: 0.88rem;
}
#pub-filter-bar .pub-filter-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.4rem;
  margin-bottom: 0.55rem;
}
#pub-filter-bar label {
  color: #777;
  margin: 0;
  white-space: nowrap;
  min-width: 2.8rem;
}
#pub-search-input {
  flex: 1 1 200px;
  padding: 0.35rem 0.65rem;
  border: 1px solid #ccc;
  border-radius: 4px;
  font-size: 0.88rem;
  font-family: inherit;
}
#pub-clear-btn {
  padding: 0.35rem 0.7rem;
  border: 1px solid #ccc;
  border-radius: 4px;
  background: #f5f5f5;
  cursor: pointer;
  font-size: 0.82rem;
  font-family: inherit;
}
#pub-clear-btn:hover { background: #e8e8e8; }
.pub-year-input {
  width: 72px;
  padding: 0.33rem 0.5rem;
  border: 1px solid #ccc;
  border-radius: 4px;
  font-size: 0.86rem;
  font-family: inherit;
  text-align: center;
}
.pub-year-sep { color: #999; padding: 0 2px; }
.pub-type-chip {
  padding: 0.28rem 0.65rem;
  border-radius: 999px;
  border: 1px solid currentColor;
  cursor: pointer;
  font-size: 0.78rem;
  font-family: inherit;
  background: transparent;
  transition: background 0.12s, color 0.12s;
  white-space: nowrap;
}
.pub-type-chip.chip-active { color: #fff !important; border-color: transparent !important; }
.pub-type-chip[data-type="all"]           { color: #555; border-color: #aaa; }
.pub-type-chip[data-type="article"]       { color: #1976D2; }
.pub-type-chip[data-type="inproceedings"] { color: #388E3C; }
.pub-type-chip[data-type="book"]          { color: #7B1FA2; }
.pub-type-chip[data-type="other"]         { color: #7a7a7a; }
.pub-type-chip.chip-active[data-type="all"]           { background: #555; }
.pub-type-chip.chip-active[data-type="article"]       { background: #1976D2; }
.pub-type-chip.chip-active[data-type="inproceedings"] { background: #388E3C; }
.pub-type-chip.chip-active[data-type="book"]          { background: #7B1FA2; }
.pub-type-chip.chip-active[data-type="other"]         { background: #7a7a7a; }
#pub-count { font-size: 0.83rem; color: #666; margin-top: 0.15rem; }
.pub-type-tag {
  display: inline-block;
  font-size: 0.7rem !important;
  font-weight: 600;
  padding: 2px 8px !important;
  border-radius: 3px;
  text-decoration: none !important;
  cursor: default;
  user-select: none;
  border: 1px solid currentColor;
  line-height: 1.5;
  margin-right: 2px;
}
.pub-type-tag[data-type="article"]       { color: #1976D2; }
.pub-type-tag[data-type="inproceedings"] { color: #388E3C; }
.pub-type-tag[data-type="book"]          { color: #7B1FA2; }
.pub-type-tag[data-type="other"]         { color: #7a7a7a; }
a.pub-bib-btn { font-size: 0.7rem !important; }
.pub-bibtex-block { display: none; margin-top: 0.5rem; }
.pub-bibtex-block.bib-open { display: block; }
.pub-bibtex-block pre {
  background: #f8f8f8;
  border: 1px solid #ddd;
  border-radius: 4px;
  padding: 0.75rem;
  font-size: 0.74rem;
  overflow-x: auto;
  white-space: pre;
  margin: 0;
}
.pub-entry-num {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  color: #aaa;
  min-width: 2rem;
  text-align: right;
  margin-right: 0.4rem;
  line-height: 1.6;
  user-select: none;
  vertical-align: top;
}
</style>

<div id="pub-filter-bar">
  <div class="pub-filter-row">
    <label>Search</label>
    <input id="pub-search-input" type="text" placeholder="title, author, venue…" autocomplete="off">
    <button id="pub-clear-btn">✕ Clear all</button>
  </div>
  <div class="pub-filter-row">
    <label>Type</label>
    <button class="pub-type-chip chip-active" data-type="all">All</button>
    <button class="pub-type-chip" data-type="article">Journal</button>
    <button class="pub-type-chip" data-type="inproceedings">Conference</button>
    <button class="pub-type-chip" data-type="book">Book</button>
    <button class="pub-type-chip" data-type="other">Other</button>
  </div>
  <div class="pub-filter-row">
    <label>Years</label>
    <input class="pub-year-input" id="pub-year-from" type="number" placeholder="from" min="1990" max="2030">
    <span class="pub-year-sep">–</span>
    <input class="pub-year-input" id="pub-year-to"   type="number" placeholder="to"   min="1990" max="2030">
  </div>
  <div id="pub-count">Showing <strong id="pub-count-n">…</strong> publications</div>
</div>

<script>
/* Wait until the full page (all scripts, images) has loaded */
window.addEventListener('load', function pubFilterInit() {

  var KNOWN = { article: true, inproceedings: true, book: true };
  function canon(t) { return KNOWN[t] ? t : 'other'; }

  var pub  = document.querySelector('.publications');
  if (!pub) return;
  var items = pub.querySelectorAll('ol.bibliography > li');
  if (!items.length) return;

  /* ── 1. Decorate each <li> ───────────────────────────────── */
  for (var i = 0; i < items.length; i++) {
    var li   = items[i];
    var meta = li.querySelector('.pub-meta-hook');
    if (!meta) continue;

    var rawType   = meta.getAttribute('data-type-key')   || 'other';
    var typeLabel = meta.getAttribute('data-type-label') || 'Other';
    var entryKey  = meta.getAttribute('data-entry-key')  || '';
    var entryYear = parseInt(meta.getAttribute('data-entry-year') || '0', 10);
    var cType     = canon(rawType);

    /* data attributes for filtering */
    li.setAttribute('data-t', cType);
    li.setAttribute('data-y', entryYear);

    /* search text: title + author only (avoid badge noise) */
    var titleEl  = li.querySelector('.title');
    var authorEl = li.querySelector('.author');
    var periodEl = li.querySelector('.periodical');
    var txt = [titleEl, authorEl, periodEl]
      .map(function(el) { return el ? el.textContent : ''; })
      .join(' ').toLowerCase();
    li.setAttribute('data-s', txt);

    /* type badge prepended to .links */
    var links = li.querySelector('.links');
    if (links && !links.querySelector('.pub-type-tag')) {
      var badge    = document.createElement('a');
      badge.className = 'pub-type-tag btn btn-sm z-depth-0';
      badge.setAttribute('data-type', cType);
      badge.setAttribute('role', 'button');
      badge.textContent = typeLabel;
      links.insertBefore(badge, links.firstChild);
    }

    /* Bib toggle: find script.pub-raw-bibtex inside this li */
    var bibScript = li.querySelector('script.pub-raw-bibtex');
    var links2    = li.querySelector('.links');
    if (bibScript && links2 && !li.querySelector('.pub-bib-btn')) {
      var rawBib = bibScript.textContent || bibScript.innerText || '';
      rawBib = rawBib.trim();

      var btn = document.createElement('a');
      btn.className = 'pub-bib-btn btn btn-sm z-depth-0';
      btn.setAttribute('role', 'button');
      btn.textContent = 'Bib';
      links2.appendChild(btn);

      /* attach block to the col div — find it by walking children */
      var colDiv = null;
      var children = li.querySelectorAll('div[id]');
      for (var c = 0; c < children.length; c++) {
        if (children[c].getAttribute('id') === entryKey) {
          colDiv = children[c];
          break;
        }
      }
      /* fallback: just append to the li */
      var container = colDiv || li;

      var block = document.createElement('div');
      block.className = 'pub-bibtex-block';
      var pre = document.createElement('pre');
      pre.textContent = rawBib;
      block.appendChild(pre);
      container.appendChild(block);

      /* closure over btn+block */
      (function(b, bl) {
        b.addEventListener('click', function() {
          var open = bl.classList.toggle('bib-open');
          b.classList.toggle('active', open);
        });
      })(btn, block);
    }
  }

  /* ── 2. Number visible entries (descending) ──────────────── */
  function renumber() {
    var visible = [];
    for (var i = 0; i < items.length; i++) {
      if (items[i].style.display !== 'none') visible.push(items[i]);
    }
    var n = visible.length;
    for (var j = 0; j < visible.length; j++) {
      var numSpan = visible[j].querySelector('.pub-entry-num');
      if (!numSpan) {
        numSpan = document.createElement('span');
        numSpan.className = 'pub-entry-num';
        visible[j].insertBefore(numSpan, visible[j].firstChild);
      }
      numSpan.textContent = (n - j) + '.';
    }
    /* clear hidden */
    for (var i = 0; i < items.length; i++) {
      if (items[i].style.display === 'none') {
        var s = items[i].querySelector('.pub-entry-num');
        if (s) s.textContent = '';
      }
    }
  }

  /* ── 3. Filter ───────────────────────────────────────────── */
  var activeType = 'all';
  var searchTxt  = '';
  var yFrom = null;
  var yTo   = null;

  function filter() {
    var count = 0;
    for (var i = 0; i < items.length; i++) {
      var li = items[i];
      var t  = li.getAttribute('data-t') || 'other';
      var y  = parseInt(li.getAttribute('data-y') || '0', 10);
      var s  = li.getAttribute('data-s') || '';
      var ok = (activeType === 'all' || t === activeType)
            && (!searchTxt || s.indexOf(searchTxt) >= 0)
            && (!yFrom || y >= yFrom)
            && (!yTo   || y <= yTo);
      li.style.display = ok ? '' : 'none';
      if (ok) count++;
    }
    /* hide empty year sections */
    var nodes = pub.children;
    for (var i = 0; i < nodes.length; i++) {
      var node = nodes[i];
      if (node.tagName === 'H2') {
        var ol = null;
        for (var j = i + 1; j < nodes.length && nodes[j].tagName !== 'H2'; j++) {
          if (nodes[j].tagName === 'OL') { ol = nodes[j]; break; }
        }
        if (ol) {
          var any = false;
          var lis = ol.querySelectorAll('li');
          for (var k = 0; k < lis.length; k++) {
            if (lis[k].style.display !== 'none') { any = true; break; }
          }
          node.style.display = any ? '' : 'none';
          ol.style.display   = any ? '' : 'none';
        }
      }
    }
    var countEl = document.getElementById('pub-count-n');
    if (countEl) countEl.textContent = count;
    renumber();
  }

  /* run once to set initial count + numbers */
  filter();

  /* ── 4. Wire controls ────────────────────────────────────── */
  var searchEl = document.getElementById('pub-search-input');
  var clearBtn = document.getElementById('pub-clear-btn');
  var yFromEl  = document.getElementById('pub-year-from');
  var yToEl    = document.getElementById('pub-year-to');
  var chips    = document.querySelectorAll('.pub-type-chip');

  if (searchEl) searchEl.addEventListener('input', function() {
    searchTxt = this.value.trim().toLowerCase();
    filter();
  });

  if (yFromEl) yFromEl.addEventListener('input', function() {
    yFrom = this.value ? parseInt(this.value, 10) : null;
    filter();
  });

  if (yToEl) yToEl.addEventListener('input', function() {
    yTo = this.value ? parseInt(this.value, 10) : null;
    filter();
  });

  if (clearBtn) clearBtn.addEventListener('click', function() {
    if (searchEl) searchEl.value = '';
    if (yFromEl)  yFromEl.value  = '';
    if (yToEl)    yToEl.value    = '';
    searchTxt = ''; yFrom = null; yTo = null; activeType = 'all';
    for (var i = 0; i < chips.length; i++) {
      chips[i].classList.toggle('chip-active', chips[i].getAttribute('data-type') === 'all');
    }
    filter();
  });

  for (var i = 0; i < chips.length; i++) {
    (function(chip) {
      chip.addEventListener('click', function() {
        activeType = chip.getAttribute('data-type');
        for (var j = 0; j < chips.length; j++) {
          chips[j].classList.toggle('chip-active', chips[j] === chip);
        }
        filter();
      });
    })(chips[i]);
  }

});
</script>
