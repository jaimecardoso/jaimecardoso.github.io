{% comment %}_includes/bib_search.liquid{% endcomment %}

<style>
/* ── Filter bar ─────────────────────────────────────────── */
#pub-filter-bar {
  margin-bottom: 1.4rem;
  font-size: 0.88rem;
}
#pub-filter-bar .pub-filter-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.4rem;
  margin-bottom: 0.5rem;
}
#pub-filter-bar label {
  color: #777;
  margin: 0;
  white-space: nowrap;
}
#pub-search-input {
  flex: 1 1 200px;
  padding: 0.35rem 0.65rem;
  border: 1px solid #ccc;
  border-radius: 4px;
  font-size: 0.88rem;
  font-family: inherit;
  min-width: 0;
}
#pub-clear-btn {
  padding: 0.35rem 0.7rem;
  border: 1px solid #ccc;
  border-radius: 4px;
  background: #f5f5f5;
  cursor: pointer;
  font-size: 0.82rem;
  white-space: nowrap;
  font-family: inherit;
}
#pub-clear-btn:hover { background: #e8e8e8; }

/* type chips */
.pub-type-chip {
  padding: 0.28rem 0.65rem;
  border-radius: 999px;
  border: 1px solid currentColor;
  cursor: pointer;
  font-size: 0.78rem;
  font-family: inherit;
  background: transparent;
  transition: background 0.12s, color 0.12s;
  white-space: nowrap;
}
.pub-type-chip.active {
  color: #fff !important;
  border-color: transparent !important;
}
.pub-type-chip[data-type="all"]          { color: #555; border-color: #aaa; }
.pub-type-chip[data-type="article"]      { color: #1976D2; }
.pub-type-chip[data-type="inproceedings"]{ color: #388E3C; }
.pub-type-chip[data-type="book"]         { color: #7B1FA2; }
.pub-type-chip[data-type="incollection"] { color: #E65100; }
.pub-type-chip[data-type="techreport"]   { color: #5D4037; }
.pub-type-chip[data-type="thesis"]       { color: #0288D1; }
.pub-type-chip[data-type="misc"]         { color: #546E7A; }

.pub-type-chip.active[data-type="all"]           { background: #555; }
.pub-type-chip.active[data-type="article"]       { background: #1976D2; }
.pub-type-chip.active[data-type="inproceedings"] { background: #388E3C; }
.pub-type-chip.active[data-type="book"]          { background: #7B1FA2; }
.pub-type-chip.active[data-type="incollection"]  { background: #E65100; }
.pub-type-chip.active[data-type="techreport"]    { background: #5D4037; }
.pub-type-chip.active[data-type="thesis"]        { background: #0288D1; }
.pub-type-chip.active[data-type="misc"]          { background: #546E7A; }

/* count */
#pub-count { font-size: 0.83rem; color: #666; }

/* ── Per-entry type badge (same look as the DOI button) ─── */
.pub-type-tag {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 3px;
  text-decoration: none !important;
  cursor: default;
  user-select: none;
  vertical-align: middle;
  /* match al-folio btn look */
  border: 1px solid currentColor;
  line-height: 1.5;
  margin-right: 2px;
}
.pub-type-tag[data-type="article"]      { color: #1976D2; }
.pub-type-tag[data-type="inproceedings"]{ color: #388E3C; }
.pub-type-tag[data-type="book"]         { color: #7B1FA2; }
.pub-type-tag[data-type="incollection"] { color: #E65100; }
.pub-type-tag[data-type="techreport"]   { color: #5D4037; }
.pub-type-tag[data-type="thesis"]       { color: #0288D1; }
.pub-type-tag[data-type="misc"],
.pub-type-tag[data-type="other"]        { color: #546E7A; }

/* ── BibTeX toggle button (matches DOI btn style) ────────── */
a.pub-bib-btn {
  font-size: 0.7rem !important;
}
/* Collapsible bibtex block (same as al-folio .abstract.hidden) */
.pub-bibtex-block {
  display: none;
  margin-top: 0.5rem;
}
.pub-bibtex-block.open { display: block; }
.pub-bibtex-block pre {
  background: #f8f8f8;
  border: 1px solid #ddd;
  border-radius: 4px;
  padding: 0.75rem;
  font-size: 0.75rem;
  overflow-x: auto;
  white-space: pre;
}
</style>

<!-- ── Filter bar markup ──────────────────────────────────────── -->
<div id="pub-filter-bar">

  <div class="pub-filter-row">
    <input id="pub-search-input" type="text" placeholder="Search title, author, venue…" aria-label="Search publications" autocomplete="off">
    <button id="pub-clear-btn">✕ Clear</button>
  </div>

  <div class="pub-filter-row">
    <label>Type:</label>
    <button class="pub-type-chip active" data-type="all">All</button>
    <button class="pub-type-chip" data-type="article">Journal</button>
    <button class="pub-type-chip" data-type="inproceedings">Conference</button>
    <button class="pub-type-chip" data-type="book">Book</button>
    <button class="pub-type-chip" data-type="incollection">Book Chapter</button>
    <button class="pub-type-chip" data-type="techreport">Tech Report</button>
    <button class="pub-type-chip" data-type="thesis">Thesis</button>
    <button class="pub-type-chip" data-type="misc">Preprint</button>
  </div>

  <div id="pub-count">Showing <strong id="pub-count-n">…</strong> publications</div>
</div>

<!-- ── All logic in one self-contained script ─────────────────── -->
<script>
(function () {
  "use strict";

  /* ── Run after DOM is ready ─────────────────────────────── */
  function ready(fn) {
    if (document.readyState !== "loading") fn();
    else document.addEventListener("DOMContentLoaded", fn);
  }

  ready(function () {

    /* ── 1. Gather every <li> that jekyll-scholar produced.
            Structure: h2(year) → ol.bibliography → li → div.row → div#key
            We need the <li> as our filter unit.                   ── */
    var pubsDiv   = document.querySelector(".publications");
    if (!pubsDiv) return;

    var allLi = Array.from(pubsDiv.querySelectorAll("ol.bibliography > li"));
    if (!allLi.length) return;

    /* ── 2. For each <li>, read the hook's hidden meta div,
            stamp data attributes onto the <li>, inject type badge
            and BibTeX button into the .links div.                  ── */
    allLi.forEach(function (li) {

      var meta = li.querySelector(".pub-meta-hook");
      if (!meta) return;

      var typeKey   = meta.getAttribute("data-type-key")   || "other";
      var typeLabel = meta.getAttribute("data-type-label") || "Other";
      var entryKey  = meta.getAttribute("data-entry-key")  || "";
      var entryYear = meta.getAttribute("data-entry-year") || "0";

      /* stamp the <li> for filtering */
      li.setAttribute("data-pub-type", typeKey);
      li.setAttribute("data-pub-year", entryYear);
      li.setAttribute("data-pub-text", li.textContent.toLowerCase());

      /* ── type badge: prepend to .links div ── */
      var linksDiv = li.querySelector(".links");
      if (linksDiv) {
        var badge = document.createElement("a");
        badge.className = "pub-type-tag btn btn-sm z-depth-0";
        badge.setAttribute("data-type", typeKey);
        badge.setAttribute("role", "button");
        badge.textContent = typeLabel;
        badge.style.cursor = "default";
        linksDiv.insertBefore(badge, linksDiv.firstChild);
      }

      /* ── BibTeX toggle button + collapsible block ── */
      var bibScript = li.querySelector(".pub-raw-bibtex");
      if (bibScript && linksDiv) {
        var rawBib = bibScript.textContent.trim();

        /* button */
        var bibBtn = document.createElement("a");
        bibBtn.className = "pub-bib-btn btn btn-sm z-depth-0";
        bibBtn.setAttribute("role", "button");
        bibBtn.textContent = "Bib";
        linksDiv.appendChild(bibBtn);

        /* collapsible block */
        var bibBlock = document.createElement("div");
        bibBlock.className = "pub-bibtex-block";
        var pre = document.createElement("pre");
        pre.textContent = rawBib;
        bibBlock.appendChild(pre);

        /* insert block after the main col div */
        var colDiv = li.querySelector("[id='" + entryKey + "']");
        if (colDiv) {
          colDiv.appendChild(bibBlock);
        }

        /* toggle on click */
        bibBtn.addEventListener("click", function () {
          var open = bibBlock.classList.toggle("open");
          bibBtn.classList.toggle("active", open);
        });
      }
    });

    /* ── 3. Filter state ──────────────────────────────────── */
    var activeType  = "all";
    var searchText  = "";

    /* ── 4. Apply filters: show/hide <li>s, then hide empty
            h2+ol year sections.                               ── */
    function applyFilters() {
      var visible = 0;

      allLi.forEach(function (li) {
        var t   = li.getAttribute("data-pub-type") || "other";
        var txt = li.getAttribute("data-pub-text") || "";

        var typeOk   = (activeType === "all") || (t === activeType);
        var searchOk = !searchText || txt.indexOf(searchText) !== -1;

        var show = typeOk && searchOk;
        li.style.display = show ? "" : "none";
        if (show) visible++;
      });

      /* hide year h2 headings whose following ol has no visible <li> */
      var nodes = Array.from(pubsDiv.children);
      var i = 0;
      while (i < nodes.length) {
        var node = nodes[i];
        if (node.tagName === "H2") {
          /* find the ol that follows this h2 */
          var ol = null;
          var j = i + 1;
          while (j < nodes.length && nodes[j].tagName !== "H2") {
            if (nodes[j].tagName === "OL") { ol = nodes[j]; break; }
            j++;
          }
          if (ol) {
            var hasVisible = Array.from(ol.querySelectorAll("li"))
                               .some(function (li) { return li.style.display !== "none"; });
            node.style.display = hasVisible ? "" : "none";
            ol.style.display   = hasVisible ? "" : "none";
          }
        }
        i++;
      }

      document.getElementById("pub-count-n").textContent = visible;
    }

    /* initial count (brief delay so DOM is fully painted) */
    setTimeout(function () {
      document.getElementById("pub-count-n").textContent = allLi.length;
    }, 50);

    /* ── 5. Wire up controls ─────────────────────────────── */

    /* search */
    document.getElementById("pub-search-input").addEventListener("input", function () {
      searchText = this.value.trim().toLowerCase();
      applyFilters();
    });

    /* clear */
    document.getElementById("pub-clear-btn").addEventListener("click", function () {
      document.getElementById("pub-search-input").value = "";
      searchText = "";
      activeType = "all";
      document.querySelectorAll(".pub-type-chip").forEach(function (c) {
        c.classList.toggle("active", c.getAttribute("data-type") === "all");
      });
      applyFilters();
    });

    /* type chips */
    document.querySelectorAll(".pub-type-chip").forEach(function (chip) {
      chip.addEventListener("click", function () {
        activeType = chip.getAttribute("data-type");
        document.querySelectorAll(".pub-type-chip").forEach(function (c) {
          c.classList.toggle("active", c === chip);
        });
        applyFilters();
      });
    });

  }); /* end ready */
}());
</script>
